# SPDX-License-Identifier: Apache-2.0

[worker]
# Execution mode: "host" or "container"
#   host      - tasks execute directly on the host system
#   container - tasks execute inside a managed Docker execution container
execution_mode = "container"
# DEPRECATED: use execution_mode instead
# mode = "container"

node_id = "<unique-node-id>"
master_url = "https://<master-domain>:9210"
workspace = "/workspace"      # container: path inside container; host: "/" (full filesystem)
command_timeout = 120
max_output_size = 200000      # max result output bytes before truncation
reconnect_interval = 5

[auth]
node_token = "<your-node-token>"
